# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Bright Data ───────────────────────────────────────────────────────────────
# Get your API token at: https://app.brightdata.com/account (API section)
BRIGHT_DATA_API_TOKEN=

# Zone names — find these in Bright Data dashboard → Proxies & Scraping
# IMPORTANT: zone names are account-specific. Common defaults shown below.
BRIGHT_DATA_SERP_ZONE=serp_api
BRIGHT_DATA_UNLOCKER_ZONE=web_unlocker1
BRIGHT_DATA_BROWSER_ZONE=scraping_browser1

# Bright Data MCP Server — hosted endpoint, token is passed as query param
BRIGHT_DATA_MCP_URL=https://mcp.brightdata.com/mcp

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=
