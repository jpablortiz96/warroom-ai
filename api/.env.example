# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Bright Data — shared token ────────────────────────────────────────────────
# Get your API token at: https://app.brightdata.com/account (API section)
BRIGHT_DATA_API_TOKEN=

# ── Bright Data — zone names (find in dashboard → Proxies & Scraping) ─────────
BRIGHT_DATA_SERP_ZONE=serp_api
BRIGHT_DATA_UNLOCKER_ZONE=unlocker_warroom
BRIGHT_DATA_BROWSER_ZONE=browser_warroom

# ── Bright Data — Scraping Browser CDP credentials ────────────────────────────
# From: dashboard → Scraping Browser zone → Access Parameters
BRIGHT_DATA_BROWSER_USER=
BRIGHT_DATA_BROWSER_PASS=

# ── Bright Data — Web Scraper API dataset ─────────────────────────────────────
# From: dashboard → Web Scraper API → your activated dataset → Dataset ID
BRIGHT_DATA_SCRAPER_DATASET_ID=

# ── Bright Data — MCP Server ──────────────────────────────────────────────────
BRIGHT_DATA_MCP_URL=https://mcp.brightdata.com/mcp

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=
